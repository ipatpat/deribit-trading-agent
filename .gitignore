# ===== Secrets & Credentials =====
.env
.env.*
*.key
*.pem
*credentials*
*secret*

# ===== Data & Databases =====
data/*.db
data/*.db-*
data/*.sqlite
data/*.sqlite-*

# ===== Documentation (excluded by request) =====
deribit_api_docs/
docs/
openspec/
frontend/openspec/

# ===== Python =====
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
build/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.coverage
.coverage.*
htmlcov/

# ===== Node / Frontend =====
node_modules/
**/node_modules/
frontend/dist/
frontend/.vite/
frontend/.next/
frontend/.cache/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ===== OS =====
Thumbs.db
ehthumbs.db
Desktop.ini

# ===== Catch-all: ignore every dotfile / dotdir =====
# Keep .gitignore itself tracked so rules ship with the repo.
.*
!.gitignore
!**/.gitignore
